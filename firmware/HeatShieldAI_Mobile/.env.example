# Copy to .env and fill in your backend's LAN IP:
#   cp .env.example .env        (macOS/Linux)
#   copy .env.example .env       (Windows cmd)
#
# Expo automatically inlines EXPO_PUBLIC_* vars into the JS bundle -- no
# extra config needed, but you MUST restart `expo start` after changing
# this file (env vars are read once at bundle time, not live-reloaded).

# The HeatShieldAI_Dashboard backend's address, reachable from your phone.
# Your phone (running Expo Go) and the computer running that backend must
# be on the SAME WiFi network. Find the backend computer's LAN IP with
# `ipconfig` (Windows) / `ifconfig` (macOS/Linux) -- same address you'd have
# used for the gateway's wifi_config.h HEATSHIELD_BACKEND_URL.
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.100:3000

# Optional, for testing against `firebase emulators:start` instead of real
# Firebase (leave both unset/blank for normal use):
# EXPO_PUBLIC_USE_AUTH_EMULATOR=1
# EXPO_PUBLIC_AUTH_EMULATOR_HOST=localhost:9099
