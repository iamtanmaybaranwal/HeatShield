# Copy this file to .env and fill in your real values. .env is gitignored
# on purpose -- it can hold secrets, so it must never be committed.
#
#   cp .env.example .env        (macOS/Linux)
#   copy .env.example .env       (Windows cmd)

# Port the dashboard server listens on. The gateway's wifi_config.h
# HEATSHIELD_BACKEND_URL must point at this port, e.g.
# http://<this-machine's-LAN-IP>:3000/api/ingest
PORT=3000

# Path to the Firebase service account JSON key file you downloaded from
# Firebase Console (Project settings > Service accounts > Generate new
# private key). Relative to this folder. See README.md for the full,
# step-by-step Firebase setup.
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Optional but recommended: a shared secret the gateway must send as the
# `x-api-key` header on every POST /api/ingest, so a random device on the
# same WiFi network can't inject fake worker readings. Leave blank while
# you're just getting things running locally -- ingestion is open with no
# key required until you set one here AND in the gateway's wifi_config.h
# (HEATSHIELD_INGEST_API_KEY).
INGEST_API_KEY=

# Required for sign-up as a supervisor to work at all (worker sign-up
# doesn't need this). Anyone who knows this code can create a supervisor
# account -- including erase-data and device-reallocation power -- from the
# login screen, so treat it like a password and share it only with people
# who should have admin access. Pick any string.
SUPERVISOR_SIGNUP_CODE=

# Firebase Web SDK config -- from Firebase Console > Project settings >
# General > "Your apps" > Add app > Web (</> icon). This is DIFFERENT from
# the service account key above: it's meant to be public (it identifies
# the project to the browser; it grants no access by itself -- Firebase
# Auth + this backend's own authorization do that). See README.md.
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_AUTH_DOMAIN=
FIREBASE_WEB_PROJECT_ID=
FIREBASE_WEB_APP_ID=
